{
  "extends": ["config:recommended"],
  "assignees": ["cujarrett"],
  "minimumReleaseAge": "7 days",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/sidecar/Dockerfile/"
      ],
      "matchStrings": [
        "HELPER_VERSION=(?<currentValue>v[\\d.]+)"
      ],
      "depNameTemplate": "aws/rolesanywhere-credential-helper",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ]
}
